# Chore Dashboard environment example
# Use this file as a reference for local/deployment-like configuration.
# Backend and frontend may be configured in separate environments in real deployments.

# =========================
# Backend (Express API)
# =========================

# API bind address and port
HOST=127.0.0.1
PORT=8000

# SQLite database path (use an absolute path in deployment-like setups)
DATABASE_PATH=chores.db

# Comma-separated browser origins allowed by CORS
# For local dev:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Request logging (opt-in)
LOG_REQUESTS=false
LOG_REQUEST_BODIES=false
LOG_REQUEST_BODY_MAX_CHARS=200

# =========================
# Frontend (Vite build/dev)
# =========================

# Public API base URL used by the frontend
VITE_API_BASE=http://localhost:8000

# =========================
# Production-like examples (commented)
# =========================

# HOST=127.0.0.1
# PORT=8000
# DATABASE_PATH=C:\ChoreDashboard\data\chores.db
# ALLOWED_ORIGINS=https://chores.example.com
# VITE_API_BASE=https://api.example.com
