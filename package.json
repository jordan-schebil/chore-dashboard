{
  "name": "chore-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api:node": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start:api:node": "node server/index.js",
    "db:backup": "node scripts/backup-db.mjs",
    "backup:windows-host:scheduled": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-scheduled-backup.ps1",
    "backup:windows-host:retention": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-backup-retention-cleanup.ps1",
    "backup:windows-host:replicate-offhost": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-offhost-backup-replicate.ps1",
    "backup:windows-host:retention:offhost": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-offhost-backup-retention-cleanup.ps1",
    "notify:windows-host:webhook": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-notify-webhook.ps1",
    "package:release": "node scripts/package-release.mjs",
    "package:release:zip": "powershell -ExecutionPolicy Bypass -File scripts/zip-release-artifact.ps1",
    "deploy:windows-host": "powershell -ExecutionPolicy Bypass -File scripts/deploy-windows-host.ps1",
    "service:windows-host:nssm": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1",
    "service:windows-host:install": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action install",
    "service:windows-host:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action uninstall",
    "service:windows-host:start": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action start",
    "service:windows-host:stop": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action stop",
    "service:windows-host:restart": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action restart",
    "service:windows-host:status": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-nssm-service.ps1 -Action status",
    "health:windows-host": "powershell -ExecutionPolicy Bypass -File scripts/windows-host-health-check.ps1",
    "test": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.js",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --open",
    "verify:release": "npm run build && npm test && npm run test:contract",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
